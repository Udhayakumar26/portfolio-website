{
  "name": "ai-ds-portfolio",
  "version": "1.0.0",
  "description": "A modern, responsive portfolio website for AI & Data Science students and professionals",
  "main": "index.html",
  "scripts": {
    "dev": "python -m http.server 8000",
    "start": "python -m http.server 8000",
    "build": "npm run minify-css && npm run minify-js && npm run optimize-images",
    "minify-css": "cleancss -o assets/css/style.min.css assets/css/style.css assets/css/animations.css assets/css/responsive.css",
    "minify-js": "terser assets/js/main.js assets/js/animations.js assets/js/form-handler.js -o assets/js/bundle.min.js",
    "optimize-images": "imagemin 'assets/images/**/*.{jpg,jpeg,png}' --out-dir=assets/images/optimized",
    "serve": "live-server --port=8080 --open=/index.html",
    "validate": "html-validate index.html",
    "lint-css": "stylelint 'assets/css/*.css'",
    "lint-js": "eslint 'assets/js/*.js'",
    "deploy": "npm run build && gh-pages -d .",
    "test": "npm run validate && npm run lint-css && npm run lint-js",
    "preview": "npm run build && npm run serve"
  },
  "keywords": [
    "portfolio",
    "ai",
    "data-science",
    "machine-learning",
    "student",
    "responsive",
    "modern",
    "javascript",
    "css3",
    "html5"
  ],
  "author": "Your Name <your.email@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/portfolio-website.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/portfolio-website/issues"
  },
  "homepage": "https://yourusername.github.io/portfolio-website",
  "devDependencies": {
    "clean-css-cli": "^5.6.2",
    "terser": "^5.19.4",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "live-server": "^1.2.2",
    "html-validate": "^8.5.0",
    "stylelint": "^15.11.0",
    "eslint": "^8.51.0",
    "gh-pages": "^6.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}